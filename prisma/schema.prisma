generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Movie {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  showTime    DateTime
  posterUrl   String?
  rating      Float?
  votes       String?  // e.g. "7.1K"
  genre       String?  // e.g. "Action, Drama"
  language    String?  // e.g. "Hindi"
  cert        String?  // e.g. "UA"
  seats       Seat[]
}

model Seat {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  row         String    // e.g., "A", "B"
  col         Int       // e.g., 1, 2
  status      String    @default("AVAILABLE") // "AVAILABLE", "LOCKED", "BOOKED"
  lockedUntil DateTime? // This is the magic concurrency field!
  
  movieId     String    @db.ObjectId
  movie       Movie     @relation(fields: [movieId], references: [id])
}